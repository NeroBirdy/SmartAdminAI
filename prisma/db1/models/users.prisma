model Users {
  id                Int      @id @default(autoincrement())
  peerId            Int      @unique
  state             String?
  city              String?
  citiesList        Json     @default("[]")
  organization      String?
  organizationsList Json     @default("[]")
  program           String?
  venueList         Json     @default("[]")
  dateList          Json     @default("[]")
  page              Int      @default(1)
  key               String?
  role              String?
  createdAt         DateTime @default(now())

  @@map("users")
}
