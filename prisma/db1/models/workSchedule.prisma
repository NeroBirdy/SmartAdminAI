enum DayOfWeek {
  MON
  TUE
  WED
  THU
  FRI
  SAT
  SUN
}

model WorkSchedule {
  id           Int       @id @default(autoincrement())
  dayOfWeek    DayOfWeek
  isWorkingDay Boolean   @default(true)
  startWork    DateTime? @db.Time(0)
  endWork      DateTime? @db.Time(0)

  // Полиморфная связь — заполняется только одно из трёх полей
  organizationId     Int?
  employeeId         Int?
  venueId            Int?
  workScheduleBreaks WorkScheduleBreaks[]
}
