model Recommendation {
  id        Int      @id @default(autoincrement())
  title     String
  text      String   @db.Text
  complete  Boolean  @default(false)
  sectionId Int
  done      Boolean  @default(false)
  section   Section  @relation(fields: [sectionId], references: [id])
  createdAt DateTime @default(now())

  @@map("recommendations")
}
