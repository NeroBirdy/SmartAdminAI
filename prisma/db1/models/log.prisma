model Log {
  id         Int        @id @default(autoincrement())
  employeeId Int?
  changeType ChangeType
  oldValue   Json
  newValue   Json
  createdAt  DateTime   @default(now())
}

enum ChangeType {
  DATE_CHANGE
  VENUE_CHANGE
  LESSON_CANCELLATION
  INSTRUCTOR_CHANGE
  LESSON_CREATE
  QUESTION_ANSWER
  ASSIGNED_TO_GROUP
  SCHEDULED_TRIAL_LESSON
  SELECTION_INSTRUCTOR_CHANGE
}
