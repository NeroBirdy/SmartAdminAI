model Group {
  id             Int     @id @default(autoincrement())
  organizationId Int
  name           String
  currentMembers Int     @default(0)
  maxMembers     Int
  instructorId   Int
  defaultVenueId Int
  programId      Int
  comment        String?
  ageCategory    String

  organization     Organization    @relation(fields: [organizationId], references: [id])
  instructor       EmployeeProgram @relation(fields: [instructorId], references: [id])
  defaultVenue     Venue           @relation("DefaultVenue", fields: [defaultVenueId], references: [id])
  additionalVenues Venue[]         @relation("AdditionalVenues")
  clients          Client[]
  lessons          Lesson[]
  schedule         Schedule[]
}
