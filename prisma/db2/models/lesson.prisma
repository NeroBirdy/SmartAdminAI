model Lesson {
  id           Int      @id @default(autoincrement())
  date         DateTime @db2.Date
  startTime    DateTime @db2.Time
  endTime      DateTime @db2.Time
  groupId      Int
  instructorId Int
  programId    Int
  venueId      Int

  group      Group           @relation(fields: [groupId], references: [id])
  instructor EmployeeProgram @relation(fields: [instructorId], references: [id])
  program    Program         @relation(fields: [programId], references: [id])
  venue      Venue           @relation(fields: [venueId], references: [id])
  schedules  Schedule[]
}
