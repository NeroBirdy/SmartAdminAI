model Program {
  id             Int    @id @default(autoincrement())
  name           String
  description    String
  organizationId Int

  organization      Organization     @relation(fields: [organizationId], references: [id])
  employeeProgram   EmployeeProgram? @relation(fields: [employeeProgramId], references: [id])
  employeeProgramId Int?
  lessons           Lesson[]
  modules           Module[]
}
