enum EmployeeRole {
  MANAGER // Руководитель
  INSTRUCTOR // Инструктор
}

model Employee {
  id             Int          @id @default(autoincrement())
  firstName      String
  lastName       String
  role           EmployeeRole
  organizationId Int
  accessCode     String       @unique

  organization     Organization      @relation(fields: [organizationId], references: [id])
  employeePrograms EmployeeProgram[]
  groups           Group[]
}
