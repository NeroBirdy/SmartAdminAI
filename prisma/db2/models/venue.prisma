model Venue {
  id               Int            @id @default(autoincrement())
  name             String
  cityId           Int
  address          String
  city             City           @relation(fields: [cityId], references: [id], onDelete: Cascade)
  groupsDefault    Group[]        @relation("DefaultVenue")
  groupsAdditional Group[]        @relation("AdditionalVenues")
  lessons          Lesson[]
  workSchedules    WorkSchedule[]
}
